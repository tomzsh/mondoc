# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
# Injected wallets (MetaMask etc.) work without this; WalletConnect QR needs it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: paid RPC endpoints (recommended for eth_getLogs scans)
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_MAINNET_RPC=https://rpc.monad.xyz

# After `pnpm deploy:testnet` (or forge script Deploy.s.sol) — contract addresses
NEXT_PUBLIC_LOG_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BADGE_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LOG_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BADGE_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# Scan tuning (public RPC friendly defaults)
NEXT_PUBLIC_SCAN_LOOKBACK_BLOCKS=50000
NEXT_PUBLIC_SCAN_CHUNK_SIZE=2000
