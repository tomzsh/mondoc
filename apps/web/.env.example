# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Primary RPC (wallet + eth_call). Alchemy is great for allowance checks.
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_MAINNET_RPC=https://rpc.monad.xyz

# Envio HyperSync (recommended for fast full-history scans)
# Create a free token: https://envio.dev/app/api-tokens
# Keep this server-side — do NOT use NEXT_PUBLIC_ for the token.
ENVIO_API_TOKEN=
# Set true so the client uses /api/hypersync (token never ships to the browser)
NEXT_PUBLIC_USE_HYPERSYNC=true

# Optional: dedicated eth_getLogs endpoint if HyperSync is off
# NEXT_PUBLIC_MONAD_LOGS_RPC=https://testnet-rpc.monad.xyz

# Contract addresses
NEXT_PUBLIC_LOG_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BADGE_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LOG_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BADGE_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# Fallback eth_getLogs tuning when HyperSync is disabled
NEXT_PUBLIC_SCAN_CHUNK_SIZE=100
NEXT_PUBLIC_SCAN_MIN_CHUNK=50
NEXT_PUBLIC_SCAN_CONCURRENCY=8
