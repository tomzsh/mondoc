# ─── Required for connect ─────────────────────────────────
# https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── RPC (wallet + eth_call). Alchemy recommended for speed ─
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_MAINNET_RPC=https://rpc.monad.xyz

# ─── Envio HyperSync (fast full-history scans) ─────────────
# Free token: https://envio.dev/app/api-tokens
# Server-only — do NOT prefix with NEXT_PUBLIC_
ENVIO_API_TOKEN=
NEXT_PUBLIC_USE_HYPERSYNC=true

# Optional: eth_getLogs endpoint if HyperSync is off
# NEXT_PUBLIC_MONAD_LOGS_RPC=https://testnet-rpc.monad.xyz

# ─── Contracts (Monad Testnet — see packages/contracts/deployments.testnet.json)
NEXT_PUBLIC_LOG_ADDRESS_TESTNET=0x433e9B7d88332207EFa8f98A463267bFd649F661
NEXT_PUBLIC_LOG_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# Fallback eth_getLogs tuning (when HyperSync disabled)
NEXT_PUBLIC_SCAN_CHUNK_SIZE=100
NEXT_PUBLIC_SCAN_MIN_CHUNK=50
NEXT_PUBLIC_SCAN_CONCURRENCY=8
